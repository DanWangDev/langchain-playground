# DeepSeek API — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Qwen / DashScope API — https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=sk-your-dashscope-key-here

# LangSmith — https://smith.langchain.com (free tier available)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__your-langsmith-key-here
LANGCHAIN_PROJECT=langchain-playground

# AWS Bedrock — uses default boto3 credential chain (~/.aws/credentials, env, instance profile)
# No explicit key needed — just ensure aws sts get-caller-identity works
AWS_REGION=us-east-1
